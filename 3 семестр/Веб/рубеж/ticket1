3. FastCGI + Fetch API, делающий HTML с приветствием через GET на Java и Apache)


public class HelloFastCGI{
    public void main(String[] args) throws IOException{
        FCGIInterface fcginterface = new FCGIInterface();
        while (fcginterface.accept()>=0){
            try {
                String queryString = getProperty("QUERY_STRING");
                Map<String, String> params = queryParser(queryString);

                params.getOrDefault("name", "гость")

                String html = "<html><body><h1>Привет, " + name + "!</h1></body></html>";
                String response = "Status: 200 OK\\r\\n" +
                                "Content-Type: text/html; charset=utf-8\\r\\n" +
                                "Content-Length: " + html.getBytes(StandardCharsets.UTF_8).length + "\\r\\n\\r\\n" +
                                html;
                FCGIInterface.request.outStream.write(response.getBytes(StandardCharsets.UTF_8));
                FCGIInterface.request.outStream.flush();
            }
        }
    }
}

<IfModule mod_fcgid.c>
    ScriptAlias /fcgi-bin/ "/var/www/html/fcgi-bin/"
    <Directory "/var/www/html/fcgi-bin/">
        Require all granted
        SetHandler fcgid-script
    </Directory>
</IfModule>

<html>
<body>
    <head>
        <meta charset="UTF-8">
    <\head>
    <script>
        fetch("/fcgi-bin/HelloFastCGI?name=Иван")
            .then(response => response.text)
            .then(html => document.body.innerHTML = html);
    <\script>
<\body>
<\html>

