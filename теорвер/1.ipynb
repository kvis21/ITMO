   "source": [
    "from math import factorial\n",
    "\n",
    "C = lambda y, x: factorial(x) / (factorial(y) * factorial(x - y))\n",
    "P = lambda n, m: C(n, 4*m)/C(n, 5*m)\n",
    "\n",
    "P(21, 3)\n",
    "\n"
